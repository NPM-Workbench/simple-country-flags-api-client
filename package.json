{
  "name": "simple-country-flags-api-client",
  "description": "simple-country-flags-api-client is a tiny TypeScript/JavaScript helper that generates type‑safe image URLs for country flags from https://flagsapi.com/ and exposes a curated, strongly‑typed list of supported countries for UI dropdowns and selectors.",
  "type": "module",
  "version": "0.9.0-beta.1",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --verbose"
  },
  "keywords": [
    "flags",
    "country-flags",
    "country-codes",
    "iso-3166",
    "flagsapi",
    "flag-icons",
    "country-selector",
    "dropdown",
    "typescript",
    "frontend"
  ],
  "license": "MIT",
  "dependencies": {
    "dayjs": "^1.11.19"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.4.6"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NPM-Workbench/simple-country-flags-api-client"
  },
  "homepage": "https://github.com/NPM-Workbench/simple-country-flags-api-client",
  "bugs": {
    "url": "https://github.com/NPM-Workbench/simple-country-flags-api-client/issues"
  }
}
